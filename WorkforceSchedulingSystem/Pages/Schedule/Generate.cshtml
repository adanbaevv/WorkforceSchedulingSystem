@page
@using System.Globalization
@model API.Pages.Schedule.GenerateModel
@{
    ViewData["Title"] = "Generate Schedule";
}

<h1 class="mb-3">Generate Weekly Schedule</h1>

<div class="card shadow-sm border-0 mb-4">
    <div class="card-body">
        <h5 class="fw-semibold mb-2">
            <i class="bi bi-stars me-1" style="color: var(--brand-primary);"></i>
            Auto-schedule a week
        </h5>
        <p class="mb-2 text-muted">
            Tell the system which shifts you need filled next week. The scheduler will look at your team's
            availability, balance hours fairly, and propose who should work each shift. Review the
            proposal, edit if needed, then commit.
        </p>
        <p class="mb-0 text-muted small">
            <strong>Tip:</strong> Add one row per person you need. If you need two baristas on Saturday 10–18,
            add two Saturday 10–18 rows — the scheduler will assign different employees to each.
        </p>
    </div>
</div>

<div class="card shadow-sm border-0 mb-4">
    <div class="card-body">
        <form method="post" asp-page-handler="Generate" id="generateForm">
            <div class="row mb-4 align-items-end">
                <div class="col-md-4">
                    <label class="form-label">Week start date</label>
                    <input type="date" name="Input.WeekStartDate" id="weekStartDate" class="form-control"
                           value="@Model.Input.WeekStartDate.ToString("yyyy-MM-dd")" />
                </div>
                <div class="col-md-auto">
                    <div class="d-flex gap-2 mt-2">
                        <button type="button" class="btn btn-outline-secondary" onclick="setWeek(0)">This week</button>
                        <button type="button" class="btn btn-outline-secondary" onclick="setWeek(1)">Next week</button>
                    </div>
                </div>
            </div>

            <h6 class="fw-semibold mb-2">Shifts you need to fill</h6>
            <table class="table mb-3" id="slotsTable">
                <thead>
                    <tr>
                        <th style="width: 40%;">Date</th>
                        <th>Start</th>
                        <th>End</th>
                        <th style="width: 60px;"></th>
                    </tr>
                </thead>
                <tbody id="slotsTableBody">
                    @for (int i = 0; i < Model.Input.Slots.Count; i++)
                    {
                        <tr>
                            <td>
                                <input type="date" name="Input.Slots[@i].Date" class="form-control form-control-sm"
                                       value="@Model.Input.Slots[i].Date.ToString("yyyy-MM-dd")" />
                            </td>
                            <td>
                                <input type="time" name="Input.Slots[@i].StartTime" class="form-control form-control-sm"
                                       value="@Model.Input.Slots[i].StartTime.ToString(@"hh\:mm")" />
                            </td>
                            <td>
                                <input type="time" name="Input.Slots[@i].EndTime" class="form-control form-control-sm"
                                       value="@Model.Input.Slots[i].EndTime.ToString(@"hh\:mm")" />
                            </td>
                            <td>
                                <button type="button" class="btn btn-sm btn-outline-danger" onclick="removeRow(this)" title="Remove this shift">&times;</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>

            <div class="d-flex justify-content-between align-items-center">
                <button type="button" class="btn btn-outline-primary" onclick="addRow()">
                    <i class="bi bi-plus-lg me-1"></i> Add another shift
                </button>
                <button type="submit" class="btn btn-primary btn-lg">
                    <i class="bi bi-lightning-charge me-1"></i> Generate Proposal
                </button>
            </div>
        </form>
    </div>
</div>

@if (Model.Proposal != null)
{
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-header bg-white fw-semibold d-flex align-items-center gap-2 flex-wrap">
            <span>Proposal — @Model.Proposal.WeekStartDate.ToString("MMM d") – @Model.Proposal.WeekEndDate.ToString("MMM d, yyyy")</span>
            <span class="badge rounded-pill badge-active ms-2">@Model.Proposal.Assignments.Count assigned</span>
            <span class="badge rounded-pill badge-open">@Model.Proposal.UnassignedSlots.Count unassigned</span>
        </div>
        <table class="table align-middle mb-0">
            <thead>
                <tr>
                    <th>Date</th>
                    <th>Time</th>
                    <th>Assigned To</th>
                    <th>Hours</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var assignment in Model.Proposal.Assignments)
                {
                    var initial = !string.IsNullOrEmpty(assignment.EmployeeName)
                        ? assignment.EmployeeName.Substring(0, 1).ToUpperInvariant() : "?";
                    <tr class="proposal-assigned">
                        <td>@assignment.Date.ToString("ddd, MMM d")</td>
                        <td>@assignment.StartTime.ToString(@"hh\:mm") – @assignment.EndTime.ToString(@"hh\:mm")</td>
                        <td>
                            <span class="avatar-circle me-2">@initial</span>
                            @assignment.EmployeeName
                        </td>
                        <td>@assignment.DurationHours.ToString("0.#")h</td>
                    </tr>
                }
                @foreach (var unassigned in Model.Proposal.UnassignedSlots)
                {
                    <tr class="proposal-unassigned">
                        <td>@unassigned.Date.ToString("ddd, MMM d")</td>
                        <td>@unassigned.StartTime.ToString(@"hh\:mm") – @unassigned.EndTime.ToString(@"hh\:mm")</td>
                        <td colspan="2"><em class="text-muted">Unassigned — @unassigned.Reason</em></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="card shadow-sm border-0 mb-4">
        <div class="card-header bg-white fw-semibold">Per-Employee Hours</div>
        <div class="card-body">
            @foreach (var hours in Model.Proposal.EmployeeHours.OrderByDescending(eh => eh.TotalHours))
            {
                var pct = Math.Min(100.0, hours.TotalHours / 40.0 * 100.0);
                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-1">
                        <span class="fw-semibold">@hours.EmployeeName</span>
                        <span class="text-muted small">
                            @hours.TotalHours.ToString("0.#")h / 40h
                            @if (hours.ExistingHours > 0)
                            {
                                <span>· existing @hours.ExistingHours.ToString("0.#")h + new @hours.NewlyAssignedHours.ToString("0.#")h</span>
                            }
                        </span>
                    </div>
                    <div class="progress" style="height: 18px;">
                        <div class="progress-bar" role="progressbar"
                             style="width: @pct.ToString("0.##", CultureInfo.InvariantCulture)%">
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    <form method="post" asp-page-handler="Commit" class="mb-5"
          onsubmit="return confirm('Create these shifts in the database?');">
        @{ var flat = 0; }
        @for (var i = 0; i < Model.Proposal.Assignments.Count; i++)
        {
            var a = Model.Proposal.Assignments[i];
            <input type="hidden" name="commitSlots[@flat].Date" value="@a.Date.ToString("yyyy-MM-dd")" />
            <input type="hidden" name="commitSlots[@flat].StartTime" value="@a.StartTime.ToString(@"hh\:mm\:ss")" />
            <input type="hidden" name="commitSlots[@flat].EndTime" value="@a.EndTime.ToString(@"hh\:mm\:ss")" />
            <input type="hidden" name="commitSlots[@flat].AssignedEmployeeId" value="@a.EmployeeId" />
            flat++;
        }
        @for (var i = 0; i < Model.Proposal.UnassignedSlots.Count; i++)
        {
            var u = Model.Proposal.UnassignedSlots[i];
            <input type="hidden" name="commitSlots[@flat].Date" value="@u.Date.ToString("yyyy-MM-dd")" />
            <input type="hidden" name="commitSlots[@flat].StartTime" value="@u.StartTime.ToString(@"hh\:mm\:ss")" />
            <input type="hidden" name="commitSlots[@flat].EndTime" value="@u.EndTime.ToString(@"hh\:mm\:ss")" />
            flat++;
        }

        <div class="card shadow-sm border-0">
            <div class="card-body d-flex justify-content-between align-items-center flex-wrap gap-3">
                <div>
                    <h5 class="mb-1 fw-semibold">Ready to commit?</h5>
                    <div class="text-muted small">
                        This will create real shifts on the calendar. Open shifts (gray rows) will appear
                        as <strong>Open</strong> in the schedule and can be picked up by employees later.
                    </div>
                </div>
                <button type="submit" class="btn btn-success btn-lg">
                    <i class="bi bi-check-circle me-1"></i> Commit to Schedule
                </button>
            </div>
        </div>
    </form>
}

<script>
    let nextIndex = @Model.Input.Slots.Count;

    function addRow() {
        const tbody = document.getElementById('slotsTableBody');
        const tr = document.createElement('tr');
        const today = new Date();
        const iso = today.toISOString().split('T')[0];
        tr.innerHTML = `
            <td><input type="date" class="form-control form-control-sm" name="Input.Slots[${nextIndex}].Date" value="${iso}" /></td>
            <td><input type="time" class="form-control form-control-sm" name="Input.Slots[${nextIndex}].StartTime" value="09:00" /></td>
            <td><input type="time" class="form-control form-control-sm" name="Input.Slots[${nextIndex}].EndTime" value="17:00" /></td>
            <td><button type="button" class="btn btn-sm btn-outline-danger" onclick="removeRow(this)" title="Remove this shift">&times;</button></td>
        `;
        tbody.appendChild(tr);
        nextIndex++;
    }

    function removeRow(btn) {
        btn.closest('tr').remove();
    }

    function setWeek(offsetWeeks) {
        const today = new Date();
        const day = today.getDay();
        const daysToMonday = (day === 0 ? -6 : 1 - day);
        const monday = new Date(today);
        monday.setDate(today.getDate() + daysToMonday + offsetWeeks * 7);
        const iso = monday.toISOString().split('T')[0];
        document.getElementById('weekStartDate').value = iso;
    }

    // Renumber slot inputs to contiguous [0..n) indices on submit so model binding works after removals.
    document.getElementById('generateForm').addEventListener('submit', () => {
        document.querySelectorAll('#slotsTableBody tr').forEach((tr, i) => {
            tr.querySelectorAll('input').forEach(input => {
                input.name = input.name.replace(/\[\d+\]/, `[${i}]`);
            });
        });
    });
</script>
