@page
@using Domain.Enums
@model API.Pages.Worker.RequestsModel
@{
    ViewData["Title"] = "My Requests";
}

<div class="mb-4">
    <h1 class="mb-1">My Requests</h1>
    <p class="text-muted mb-0">Ask to pick up open shifts or drop shifts you can't work</p>
</div>

<div class="card shadow-sm border-0 mb-4">
    <div class="card-header bg-white fw-semibold">Request History</div>
    @if (Model.MyRequests.Any())
    {
        <table class="table align-middle mb-0">
            <thead>
                <tr>
                    <th style="width: 100px;">Type</th>
                    <th>Shift</th>
                    <th>Reason</th>
                    <th>Requested</th>
                    <th>Status</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var request in Model.MyRequests.OrderByDescending(r => r.RequestedAt))
                {
                    Domain.Entities.Shift? shift = Model.ShiftLookup.TryGetValue(request.ShiftId, out var s) ? s : null;
                    <tr>
                        <td>
                            @if (request.RequestType == ShiftRequestType.Pickup)
                            {
                                <span class="badge rounded-pill badge-pickup">Pickup</span>
                            }
                            else
                            {
                                <span class="badge rounded-pill badge-drop">Drop</span>
                            }
                        </td>
                        <td>
                            @if (shift != null)
                            {
                                <div>@shift.Date.ToString("ddd, MMM d")</div>
                                <div class="text-muted small">@shift.StartTime.ToString(@"hh\:mm") – @shift.EndTime.ToString(@"hh\:mm")</div>
                            }
                            else
                            {
                                <span class="text-muted">(shift unavailable)</span>
                            }
                        </td>
                        <td class="text-muted fst-italic small">@(string.IsNullOrEmpty(request.Reason) ? "—" : $"\u201C{request.Reason}\u201D")</td>
                        <td class="text-muted small">@request.RequestedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                        <td>
                            @switch (request.Status)
                            {
                                case ShiftRequestStatus.Pending:
                                    <span class="badge rounded-pill badge-worker">Pending</span>
                                    break;
                                case ShiftRequestStatus.Approved:
                                    <span class="badge rounded-pill badge-active">Approved</span>
                                    break;
                                case ShiftRequestStatus.Rejected:
                                    <span class="badge rounded-pill bg-danger">Rejected</span>
                                    break;
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="empty-state">
            <i class="bi bi-inbox"></i>
            <div>You haven't submitted any requests yet.</div>
        </div>
    }
</div>

<div class="row g-4">
    <div class="col-lg-6">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-white fw-semibold">
                <i class="bi bi-box-arrow-up-right me-1" style="color: var(--drop-orange);"></i>
                Drop a Shift I Can't Work
            </div>
            <div class="card-body">
                @if (Model.MyFutureAssignedShifts.Any())
                {
                    <form method="post" asp-page-handler="Drop">
                        <div class="mb-3">
                            <label class="form-label">Shift</label>
                            <select asp-for="DropShiftId" class="form-select">
                                <option value="">— choose a shift —</option>
                                @foreach (var shift in Model.MyFutureAssignedShifts)
                                {
                                    <option value="@shift.Id">
                                        @shift.Date.ToString("ddd, MMM d") · @shift.StartTime.ToString(@"hh\:mm")–@shift.EndTime.ToString(@"hh\:mm")
                                    </option>
                                }
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Reason (optional)</label>
                            <textarea asp-for="DropReason" class="form-control" rows="3"
                                      placeholder="Why do you need to drop this shift?"></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary w-100">
                            Submit Drop Request
                        </button>
                    </form>
                }
                else
                {
                    <div class="empty-state">
                        <i class="bi bi-calendar-check"></i>
                        <div>You have no future assigned shifts to drop.</div>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-6">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-white fw-semibold">
                <i class="bi bi-box-arrow-in-down-left me-1" style="color: var(--pickup-blue);"></i>
                Pick Up an Open Shift
            </div>
            @if (Model.OpenShifts.Any())
            {
                <table class="table mb-0">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Time</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var shift in Model.OpenShifts)
                        {
                            <tr>
                                <td>@shift.Date.ToString("ddd, MMM d")</td>
                                <td>@shift.StartTime.ToString(@"hh\:mm") – @shift.EndTime.ToString(@"hh\:mm")</td>
                                <td class="text-end">
                                    <form method="post" asp-page-handler="Pickup">
                                        <input type="hidden" name="shiftId" value="@shift.Id" />
                                        <button type="submit" class="btn btn-sm btn-primary">
                                            Request to Pick Up
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="empty-state">
                    <i class="bi bi-hand-thumbs-up"></i>
                    <div>No open shifts right now.</div>
                </div>
            }
        </div>
    </div>
</div>
