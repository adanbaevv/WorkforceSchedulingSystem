@page
@model API.Pages.Worker.ScheduleModel
@{
    ViewData["Title"] = "My Schedule";
}

<div class="mb-4">
    <h1 class="mb-1">My Schedule</h1>
    <p class="text-muted mb-0">Upcoming shifts for @Model.ViewerName</p>
</div>

@if (Model.ActiveEntry != null)
{
    <div class="card shadow-sm border-0 mb-4" style="background-color: #FFF8E6;">
        <div class="card-body d-flex justify-content-between align-items-center flex-wrap gap-3">
            <div>
                <div class="fw-semibold"><i class="bi bi-clock-history me-1"></i> You are currently clocked in</div>
                <div class="text-muted small">Since @Model.ActiveEntry.ClockInAt.ToLocalTime().ToString("ddd, MMM d · HH:mm")</div>
            </div>
            <a class="btn btn-outline-danger" asp-page="/Worker/Clock">Open Clock Screen</a>
        </div>
    </div>
}

@if (Model.UpcomingShifts.Any())
{
    <div class="row g-3">
        @foreach (var shift in Model.UpcomingShifts)
        {
            var isToday = Model.IsShiftToday(shift);
            <div class="col-md-6 col-lg-4">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <div>
                                <div class="fw-semibold">@shift.Date.ToString("dddd")</div>
                                <div class="text-muted small">@shift.Date.ToString("MMM d, yyyy")</div>
                            </div>
                            @if (isToday)
                            {
                                <span class="badge rounded-pill badge-active">Today</span>
                            }
                            else
                            {
                                <span class="badge rounded-pill badge-worker">@((shift.Date.DayNumber - Model.Today.DayNumber))d away</span>
                            }
                        </div>

                        <div class="fs-5 fw-semibold mb-2">
                            @shift.StartTime.ToString(@"hh\:mm") – @shift.EndTime.ToString(@"hh\:mm")
                        </div>

                        <div class="text-muted small mb-3">
                            @((shift.EndTime - shift.StartTime).TotalHours.ToString("0.#")) hour shift
                        </div>

                        @if (isToday && Model.ActiveEntry == null)
                        {
                            <a class="btn btn-primary w-100"
                               asp-page="/Worker/Clock"
                               asp-route-shiftId="@shift.Id">
                                <i class="bi bi-play-circle me-1"></i> Clock In for this shift
                            </a>
                        }
                        else if (isToday && Model.ActiveEntry != null && Model.ActiveEntry.ShiftId == shift.Id)
                        {
                            <form method="post" asp-page="/Worker/Clock" asp-page-handler="ClockOut">
                                <input type="hidden" name="timeEntryId" value="@Model.ActiveEntry.Id" />
                                <button type="submit" class="btn btn-danger w-100">
                                    <i class="bi bi-stop-circle me-1"></i> Clock Out
                                </button>
                                <div class="text-muted small mt-1 text-center">
                                    Clocked in since @Model.ActiveEntry.ClockInAt.ToLocalTime().ToString("HH:mm")
                                </div>
                            </form>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="card shadow-sm border-0">
        <div class="empty-state">
            <i class="bi bi-calendar3"></i>
            <div class="mb-3">No upcoming shifts.</div>
            <a class="btn btn-outline-primary" asp-page="/Worker/Availability">Update your availability</a>
        </div>
    </div>
}
